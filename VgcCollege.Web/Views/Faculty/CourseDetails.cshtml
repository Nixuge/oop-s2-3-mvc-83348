@model VgcCollege.Domain.Models.Course
@{
    ViewData["Title"] = "Course Details";
}

<h1>Details for @Model.Name</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <h3>Course Info</h3>
        <p><strong>Branch:</strong> @Model.Branch?.Name</p>
        <p><strong>Dates:</strong> @Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()</p>
    </div>
</div>

<h3 class="mt-4">Enrolled Students (Contact Details)</h3>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var enrolment in Model.Enrolments)
        {
            <tr>
                <td>@enrolment.Student?.Name</td>
                <td>@enrolment.Student?.Email</td>
                <td>@enrolment.Student?.Phone</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="MyCourses" class="btn btn-secondary">Back to My Courses</a>