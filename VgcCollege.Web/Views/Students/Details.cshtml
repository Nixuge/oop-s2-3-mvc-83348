@model VgcCollege.Domain.Models.StudentProfile
@{
    ViewData["Title"] = "Student Details";
}

<h1>@ViewData["Title"]: @Model.Name</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Contact Information</h5>
            </div>
            <div class="card-body">
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.Phone</p>
                <p><strong>Address:</strong> @Model.Address</p>
                <p><strong>Student Number:</strong> @Model.StudentNumber</p>
                <p><strong>DOB:</strong> @Model.DateOfBirth.ToShortDateString()</p>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Profile</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>Course Enrolments</h5>
                <a asp-action="Enrol" asp-route-id="@Model.Id" class="btn btn-sm btn-success">Add Enrolment</a>
            </div>
            <div class="card-body">
                @if (!Model.Enrolments.Any())
                {
                    <p class="text-muted">No active enrolments.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var enrolment in Model.Enrolments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @enrolment.Course?.Name
                                <span class="badge bg-primary rounded-pill">@enrolment.Status</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>