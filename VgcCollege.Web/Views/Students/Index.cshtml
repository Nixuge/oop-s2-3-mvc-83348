@model IEnumerable<VgcCollege.Domain.Models.StudentProfile>
@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between mb-3">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-success">Create Student</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Student Number</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.Name</td>
            <td>@item.Email</td>
            <td>@item.StudentNumber</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Enrol" asp-route-id="@item.Id" class="btn btn-success btn-sm">Enrol</a>
            </td>
        </tr>
    }
    </tbody>
</table>