@model IEnumerable<VgcCollege.Domain.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between mb-3">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-success">Create Course</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Branch</th>
            <th>Faculty</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.Name</td>
            <td>@item.Branch?.Name</td>
            <td>@item.FacultyProfile?.Name</td>
            <td>@item.StartDate.ToShortDateString()</td>
            <td>@item.EndDate.ToShortDateString()</td>
            <td>
                <a asp-action="ManageResults" asp-route-id="@item.Id" class="btn btn-info btn-sm">Manage Results</a>
            </td>
        </tr>
    }
    </tbody>
</table>