@{
    ViewData["Title"] = "My Grades";
    var enrolments = ViewBag.Enrolments as IEnumerable<VgcCollege.Domain.Models.CourseEnrolment>;
    var assignmentResults = ViewBag.AssignmentResults as IEnumerable<VgcCollege.Domain.Models.AssignmentResult>;
    var examResults = ViewBag.ExamResults as IEnumerable<VgcCollege.Domain.Models.ExamResult>;
}

<h1>@ViewData["Title"]</h1>

@foreach (var enrolment in enrolments!)
{
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h3>@enrolment.Course?.Name</h3>
        </div>
        <div class="card-body">
            <h4>Assignments</h4>
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Score</th>
                        <th>Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in assignmentResults!.Where(r => r.Assignment?.CourseId == enrolment.CourseId))
                    {
                        <tr>
                            <td>@result.Assignment?.Title</td>
                            <td>@result.Score / @result.Assignment?.MaxScore</td>
                            <td>@result.Feedback</td>
                        </tr>
                    }
                </tbody>
            </table>

            <h4 class="mt-4">Exams (Released Only)</h4>
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Score</th>
                        <th>Grade</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in examResults!.Where(r => r.Exam?.CourseId == enrolment.CourseId))
                    {
                        <tr>
                            <td>@result.Exam?.Title</td>
                            <td>@result.Score / @result.Exam?.MaxScore</td>
                            <td>@result.Grade</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}