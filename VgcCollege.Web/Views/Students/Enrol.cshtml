@model VgcCollege.Domain.Models.CourseEnrolment
@{
    ViewData["Title"] = "Enrol Student in Course";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Enrol">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="StudentProfileId" />
            
            <div class="form-group mb-3">
                <label class="control-label">Select Course</label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId"></select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Enrol Student" class="btn btn-success" />
                <a asp-action="Details" asp-route-id="@Model.StudentProfileId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}