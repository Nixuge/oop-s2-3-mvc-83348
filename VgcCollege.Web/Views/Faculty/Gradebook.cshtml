@model VgcCollege.Domain.Models.Course
@{
    ViewData["Title"] = "Gradebook";
}

<h1>Gradebook for @Model.Name</h1>

@foreach (var assignment in Model.Assignments)
{
    <div class="card mb-4 mt-4">
        <div class="card-header bg-dark text-white">
            <h4>Assignment: @assignment.Title (Max Score: @assignment.MaxScore)</h4>
        </div>
        <div class="card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Student Name</th>
                        <th>Score</th>
                        <th>Feedback</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var enrolment in Model.Enrolments)
                    {
                        var result = assignment.Results.FirstOrDefault(r => r.StudentProfileId == enrolment.StudentProfileId);
                        <tr>
                            <form asp-action="UpdateAssignmentResult" method="post">
                                <input type="hidden" name="assignmentId" value="@assignment.Id" />
                                <input type="hidden" name="studentProfileId" value="@enrolment.StudentProfileId" />
                                <td>@enrolment.Student?.Name</td>
                                <td>
                                    <input type="number" step="0.1" name="score" value="@(result?.Score ?? 0)" class="form-control" style="width:100px;" />
                                </td>
                                <td>
                                    <input type="text" name="feedback" value="@(result?.Feedback ?? "")" class="form-control" />
                                </td>
                                <td>
                                    <button type="submit" class="btn btn-sm btn-primary">Save Result</button>
                                </td>
                            </form>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<a asp-action="MyCourses" class="btn btn-secondary">Back to My Courses</a>